generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("USER")
  createdAt    DateTime  @default(now())
  imageUrl     String?
  bookings     Booking[]

  @@index([email])
}

model Operator {
  id          Int      @id @default(autoincrement())
  name        String
  rating      Float?
  contactInfo String?
  createdAt   DateTime @default(now())
  logoUrl     String?
  buses       Bus[]
}

model City {
  id                Int     @id @default(autoincrement())
  name              String  @unique
  state             String?
  popularity        Int     @default(0)
  imageUrl          String?
  destinationRoutes Route[] @relation("DestinationCity")
  sourceRoutes      Route[] @relation("SourceCity")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([popularity])
}

model Route {
  id                Int           @id @default(autoincrement())
  sourceCityId      Int
  destinationCityId Int
  distanceKm        Int?
  schedules         BusSchedule[]
  destinationCity   City          @relation("DestinationCity", fields: [destinationCityId], references: [id])
  sourceCity        City          @relation("SourceCity", fields: [sourceCityId], references: [id])

  @@unique([sourceCityId, destinationCityId])
}

model Bus {
  id         Int           @id @default(autoincrement())
  operatorId Int
  busNumber  String?       @unique
  totalSeats Int
  busType    String?
  operator   Operator      @relation(fields: [operatorId], references: [id])
  schedules  BusSchedule[]
  seats      Seat[]
}

model BusSchedule {
  id            Int       @id @default(autoincrement())
  busId         Int
  routeId       Int
  departureTime DateTime?
  arrivalTime   DateTime?
  basePrice     Int?
  bookings      Booking[]
  bus           Bus       @relation(fields: [busId], references: [id])
  route         Route     @relation(fields: [routeId], references: [id])

  @@index([routeId])
  @@index([routeId, departureTime])
}

model Seat {
  id           Int           @id @default(autoincrement())
  busId        Int
  seatNumber   Int
  seatType     String?
  bookingSeats BookingSeat[]
  bus          Bus           @relation(fields: [busId], references: [id])

  @@unique([busId, seatNumber])
}

model Booking {
  id           Int           @id @default(autoincrement())
  userId       Int
  scheduleId   Int
  totalPrice   Int?
  status       String        @default("PENDING")
  createdAt    DateTime      @default(now())
  schedule     BusSchedule   @relation(fields: [scheduleId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  bookingSeats BookingSeat[]
  payment      Payment?

  @@index([userId])
  @@index([scheduleId])
}

model BookingSeat {
  id        Int     @id @default(autoincrement())
  bookingId Int
  seatId    Int
  booking   Booking @relation(fields: [bookingId], references: [id])
  seat      Seat    @relation(fields: [seatId], references: [id])

  @@unique([bookingId, seatId])
}

model Payment {
  id            Int      @id @default(autoincrement())
  bookingId     Int      @unique
  amount        Int?
  status        String?
  transactionId String?
  provider      String?
  createdAt     DateTime @default(now())
  booking       Booking  @relation(fields: [bookingId], references: [id])
}
