generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("USER")
  imageUrl     String?
  createdAt    DateTime  @default(now())

  bookings     Booking[]

  @@index([email])
}

model Operator {
  id          Int       @id @default(autoincrement())
  name        String
  rating      Float?
  contactInfo String?
  logoUrl     String?
  createdAt   DateTime  @default(now())

  buses       Bus[]
}

model City {
  id                Int      @id @default(autoincrement())
  name              String
  state             String?
  imageUrl          String?

  sourceRoutes      Route[]  @relation("SourceCity")
  destinationRoutes Route[]  @relation("DestinationCity")
}

model Route {
  id                 Int     @id @default(autoincrement())
  sourceCityId       Int
  destinationCityId  Int
  distanceKm         Int?

  sourceCity      City @relation("SourceCity", fields: [sourceCityId], references: [id])
  destinationCity City @relation("DestinationCity", fields: [destinationCityId], references: [id])

  schedules       BusSchedule[]

  @@unique([sourceCityId, destinationCityId])
}

model Bus {
  id          Int     @id @default(autoincrement())
  operatorId  Int
  busNumber   String? @unique
  totalSeats  Int
  busType     String?

  operator    Operator   @relation(fields: [operatorId], references: [id])
  schedules   BusSchedule[]
  seats       Seat[]
}

model BusSchedule {
  id            Int       @id @default(autoincrement())
  busId         Int
  routeId       Int
  departureTime DateTime?
  arrivalTime   DateTime?
  basePrice     Int?

  bus       Bus    @relation(fields: [busId], references: [id])
  route     Route  @relation(fields: [routeId], references: [id])
  bookings  Booking[]

  @@index([routeId])
  @@index([routeId, departureTime])
}

model Seat {
  id           Int     @id @default(autoincrement())
  busId        Int
  seatNumber   Int
  seatType     String?

  bus          Bus           @relation(fields: [busId], references: [id])
  bookingSeats BookingSeat[]

  @@unique([busId, seatNumber])
}

model Booking {
  id           Int      @id @default(autoincrement())
  userId       Int
  scheduleId   Int
  totalPrice   Int?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  user         User        @relation(fields: [userId], references: [id])
  schedule     BusSchedule @relation(fields: [scheduleId], references: [id])
  bookingSeats BookingSeat[]
  payment      Payment?

  @@index([userId])
  @@index([scheduleId])
}

model BookingSeat {
  id         Int @id @default(autoincrement())
  bookingId  Int
  seatId     Int

  booking    Booking @relation(fields: [bookingId], references: [id])
  seat       Seat    @relation(fields: [seatId], references: [id])

  @@unique([bookingId, seatId])
}

model Payment {
  id            Int      @id @default(autoincrement())
  bookingId     Int      @unique
  amount        Int?
  status        String?
  transactionId String?
  provider      String?
  createdAt     DateTime @default(now())

  booking       Booking @relation(fields: [bookingId], references: [id])
}